# ─── V2 Enhanced Configuration ────────────────────────────────────────────────

# Coins to scan (comma-separated Binance USDT pairs)
BINANCE_SYMBOLS=SOLUSDT,BTCUSDT,ETHUSDT,BNBUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,NEARUSDT,INJUSDT,SUIUSDT,ARBUSDT

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Scheduler (runs signal check on cron schedule)
CRON_SCHEDULE=0 * * * *

# ─── V2 Enhanced Endpoints ────────────────────────────────────────────────────
# GET  /api/v2scan
#      Multi-timeframe scanner (4H+1H+15M) with ADX, StochRSI, BB, OBV, VWAP
#
# GET  /api/v2listings
#      New listing pump scanner — min $500K liquidity, risk flags, cross-exchange validation
#
# GET  /api/v2advice?symbol=SOLUSDT&buyPrice=150&account=10000&risk=1
#      Position exit advisor — ATR stops, 3-level TPs, trailing stop, position sizing
#      Optional params: account (account balance in USD), risk (% to risk, default 1)
#
# POST /api/v2advice
#      Body: { symbol, buyPrice, accountSize, riskPct, quantity }
#
# ─── Dashboard ────────────────────────────────────────────────────────────────
# GET /dashboard — Live signal intelligence dashboard
