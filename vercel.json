{
  "version": 2,
  "builds": [
    {
      "src": "api/signal.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/backtest.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/signal",
      "dest": "/api/signal.js"
    },
    {
      "src": "/api/backtest",
      "dest": "/api/backtest.js"
    }
  ]
}
