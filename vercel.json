{
  "version": 2,
  "name": "crypto-signal-bot",
  "builds": [
    {
      "src": "api/signal.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**"]
      }
    },
    {
      "src": "api/backtest.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/signal",
      "dest": "/api/signal.js"
    },
    {
      "src": "/api/backtest",
      "dest": "/api/backtest.js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
